{
  "training_config": {
    "data_settings": {
      "train_ratio": 0.8,
      "validation_ratio": 0.1,
      "min_data_points": 100,
      "target_days": [1, 3, 7],
      "feature_selection_k": 30
    },
    
    "feature_engineering": {
      "technical_indicators": {
        "sma_periods": [5, 10, 20, 50, 100],
        "ema_periods": [12, 26, 50],
        "rsi_periods": [14, 21, 28],
        "bollinger_period": 20,
        "macd_fast": 12,
        "macd_slow": 26,
        "macd_signal": 9
      },
      
      "statistical_features": {
        "rolling_windows": [5, 10, 20, 30, 60],
        "lag_periods": [1, 2, 3, 5, 7, 14, 21],
        "volatility_windows": [5, 10, 20, 30],
        "return_periods": [1, 2, 3, 5, 7]
      },
      
      "interaction_features": {
        "enable_polynomial": true,
        "polynomial_degree": 2,
        "enable_interactions": true,
        "max_interaction_features": 50
      }
    },
    
    "model_parameters": {
      "random_forest": {
        "n_estimators": [100, 200, 300],
        "max_depth": [10, 15, 20, null],
        "min_samples_split": [2, 5, 10],
        "min_samples_leaf": [1, 2, 4],
        "max_features": ["sqrt", "log2", null]
      },
      
      "gradient_boosting": {
        "n_estimators": [100, 150, 200],
        "learning_rate": [0.05, 0.1, 0.15, 0.2],
        "max_depth": [6, 8, 10, 12],
        "min_samples_split": [2, 5, 10],
        "subsample": [0.8, 0.9, 1.0]
      },
      
      "xgboost": {
        "n_estimators": [100, 200, 300],
        "learning_rate": [0.05, 0.1, 0.15],
        "max_depth": [6, 8, 10],
        "subsample": [0.8, 0.9, 1.0],
        "colsample_bytree": [0.8, 0.9, 1.0],
        "reg_alpha": [0, 0.1, 0.5],
        "reg_lambda": [1, 1.5, 2]
      },
      
      "lightgbm": {
        "n_estimators": [100, 200, 300],
        "learning_rate": [0.05, 0.1, 0.15],
        "max_depth": [6, 8, 10],
        "num_leaves": [31, 50, 70, 100],
        "subsample": [0.8, 0.9, 1.0],
        "colsample_bytree": [0.8, 0.9, 1.0]
      },
      
      "catboost": {
        "iterations": [100, 200, 300],
        "learning_rate": [0.05, 0.1, 0.15],
        "depth": [6, 8, 10],
        "l2_leaf_reg": [1, 3, 5, 7, 9]
      },
      
      "neural_network": {
        "hidden_layer_sizes": [
          [100], [100, 50], [200, 100], [100, 50, 25],
          [200, 100, 50], [300, 150, 75]
        ],
        "activation": ["relu", "tanh"],
        "alpha": [0.0001, 0.001, 0.01],
        "learning_rate": ["constant", "adaptive"],
        "max_iter": [500, 1000, 1500]
      },
      
      "support_vector": {
        "kernel": ["rbf", "poly", "sigmoid"],
        "C": [0.1, 1, 10, 100],
        "gamma": ["scale", "auto", 0.001, 0.01, 0.1],
        "epsilon": [0.01, 0.1, 0.2]
      },
      
      "linear_models": {
        "ridge_alpha": [0.1, 1.0, 10.0, 100.0],
        "lasso_alpha": [0.01, 0.1, 1.0, 10.0],
        "elastic_alpha": [0.01, 0.1, 1.0],
        "elastic_l1_ratio": [0.1, 0.5, 0.7, 0.9]
      }
    },
    
    "ensemble_settings": {
      "voting_weights": "performance_based",
      "stacking_enabled": true,
      "meta_learner": "ridge",
      "blending_enabled": true,
      "cross_validation_folds": 5
    },
    
    "optimization": {
      "hyperparameter_tuning": {
        "method": "grid_search",
        "cv_folds": 3,
        "scoring": "neg_mean_squared_error",
        "n_jobs": -1,
        "verbose": 1
      },
      
      "feature_selection": {
        "methods": ["statistical", "rfe", "importance"],
        "k_best": 30,
        "rfe_step": 1,
        "importance_threshold": 0.001
      },
      
      "early_stopping": {
        "enabled": true,
        "patience": 10,
        "min_delta": 0.001
      }
    },
    
    "evaluation": {
      "metrics": [
        "mse", "mae", "rmse", "r2", "mape",
        "direction_accuracy", "sharpe_ratio"
      ],
      "cross_validation": {
        "method": "time_series_split",
        "n_splits": 5,
        "test_size": null
      },
      "backtesting": {
        "enabled": true,
        "walk_forward": true,
        "refit_frequency": 30
      }
    }
  },
  
  "data_preprocessing": {
    "scaling": {
      "method": "standard",
      "feature_range": [0, 1],
      "robust_scaling": false
    },
    
    "outlier_handling": {
      "method": "iqr",
      "threshold": 3.0,
      "cap_outliers": true
    },
    
    "missing_values": {
      "strategy": "drop",
      "fill_method": "forward_fill",
      "interpolation": "linear"
    }
  },
  
  "model_persistence": {
    "save_format": "joblib",
    "compression": true,
    "versioning": true,
    "metadata_tracking": true
  },
  
  "logging": {
    "level": "INFO",
    "file_logging": true,
    "console_logging": true,
    "log_file": "training.log"
  }
}